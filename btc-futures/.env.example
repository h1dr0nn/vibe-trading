# ── OKX API (private) ─────────────────────────────────────────────
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_API_PASSPHRASE=your_passphrase_here
OKX_DEMO_MODE=false              # true = paper trading (testnet)

# ── Vibe-Trading Agent ────────────────────────────────────────────
LANGCHAIN_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=your_google_api_key
LANGCHAIN_PROVIDER=gemini
GEMINI_API_KEY=your_google_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_CHAT_ID=-100123456789   # Group chat ID (negative) or user ID

# ── Bot Behaviour ─────────────────────────────────────────────────
BOT_SYMBOL=BTC-USDT-SWAP
BOT_INTERVAL_HOURS=2
POSITION_CHECK_MINUTES=5         # Fast TP/SL detection while holding a position
DRY_RUN=true                     # ALWAYS start with true

# ── Position Sizing ───────────────────────────────────────────────
ACCOUNT_BALANCE_USDT=100         # Used only when DRY_RUN=true
RISK_PCT=1.0
MAX_RISK_PCT=5.0                 # Hard ceiling per trade (safety net)
LEVERAGE=5
ORDER_TYPE=limit

# ── Signal Quality Filter ─────────────────────────────────────────
# Tight defaults — only trade when 1H + 4H + 1D all agree.
MIN_CONFIDENCE=75
MIN_NET_SCORE=0.5
MIN_AGREEING_TF=3
REQUIRE_AGENT=false

# ── Strong-signal override ────────────────────────────────────────
# Bypass daily-loss cap for A+ setups (still respects MAX_RISK_PCT).
STRONG_SIGNAL_CONF=85
STRONG_SIGNAL_AGREE=3

# ── Entry gates ───────────────────────────────────────────────────
FIFTEEN_MIN_VETO=true            # Block entries fighting 15m momentum
FIFTEEN_MIN_VETO_SCORE=0.3
RSI_GUARD=true                   # Don't chase 15m RSI extremes
RSI_OVERBOUGHT=72
RSI_OVERSOLD=28
PULLBACK_GATE=true               # Require retrace after same-direction TP close
PULLBACK_WINDOW_HOURS=12
PULLBACK_REQUIRE_ATR=0.3
PULLBACK_REQUIRE_PCT=0.3

# ── Regime filter ─────────────────────────────────────────────────
REGIME_FILTER=true               # Skip entries when 4H regime is choppy

# ── Agent in-position consultation ────────────────────────────────
AGENT_HOLD_CHECK=false           # Call agent each cycle while in position (API cost)

# ── Post-trade review log ─────────────────────────────────────────
TRADE_REVIEW_LOG=logs/trade_review.jsonl

# ── TP/SL ─────────────────────────────────────────────────────────
SL_ATR_MULT=1.5
TP1_ATR_MULT=2.0
TP2_ATR_MULT=3.5
MIN_SL_PCT=0.3
SL_PCT_MAX=1.2                   # Cap SL distance as % of entry (sizing auto-scales risk)

# ── Breakeven + Trailing SL ───────────────────────────────────────
BE_TRIGGER_R=1.0                 # Move SL to BE when profit reaches this R
BE_BUFFER_R=0.1                  # New SL = entry + 0.1R (locks tiny profit for fees)
TRAIL_TRIGGER_R=1.5              # Advance trail when profit reaches this R
TRAIL_LOCK_R=1.0                 # New SL = entry + 1R (locks 1R of profit)

# ── Circuit Breaker ───────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_HOURS=48
DANGER_CLOSE_ON_SL_PROXIMITY=false  # Close early when price nears SL (shrinks effective SL — off)
DANGER_SL_ATR_MULT=0.15
# DANGER_LOSS_PCT must be ≥ MAX_RISK_PCT so it doesn't pre-empt the real SL
# (keep as emergency brake for slippage/gap beyond designed risk, not as a soft SL)
DANGER_LOSS_PCT=10.0
DANGER_SIGNAL_FLIP=true
LOSS_COOLDOWN_MINUTES=60         # Block same-direction re-entry after a loss

# ── Pending Order ─────────────────────────────────────────────────
PENDING_CANCEL_HOURS=6
PENDING_CANCEL_DRIFT_PCT=0.5
