# ── OKX API (private) ─────────────────────────────────────────────
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_API_PASSPHRASE=your_passphrase_here
OKX_DEMO_MODE=false              # true = paper trading (testnet)

# ── Vibe-Trading Agent ────────────────────────────────────────────
LANGCHAIN_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=your_google_api_key
LANGCHAIN_PROVIDER=gemini
GEMINI_API_KEY=your_google_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_CHAT_ID=-100123456789   # Group chat ID (negative) or user ID

# ── Bot Behaviour ─────────────────────────────────────────────────
BOT_SYMBOL=BTC-USDT-SWAP
BOT_INTERVAL_HOURS=2
DRY_RUN=true                     # ALWAYS start with true

# ── Position Sizing ───────────────────────────────────────────────
ACCOUNT_BALANCE_USDT=100         # Used only when DRY_RUN=true
RISK_PCT=1.0
LEVERAGE=5
ORDER_TYPE=limit

# ── Signal Quality Filter ─────────────────────────────────────────
MIN_CONFIDENCE=60
MIN_NET_SCORE=0.3
MIN_AGREEING_TF=2
REQUIRE_AGENT=false

# ── TP/SL ─────────────────────────────────────────────────────────
SL_ATR_MULT=1.5
TP1_ATR_MULT=2.0
TP2_ATR_MULT=3.5
MIN_SL_PCT=0.3

# ── Circuit Breaker ───────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_HOURS=48
DANGER_SL_ATR_MULT=0.5
DANGER_LOSS_PCT=2.0
DANGER_SIGNAL_FLIP=true

# ── Pending Order ─────────────────────────────────────────────────
PENDING_CANCEL_HOURS=6
PENDING_CANCEL_DRIFT_PCT=0.5
